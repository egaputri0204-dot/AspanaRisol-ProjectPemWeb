<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Aspana Risol</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;700&display=swap"
      rel="stylesheet"
    >

    <!-- Feather Icons -->
    <script src="https://unpkg.com/feather-icons"></script>

    <!-- CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">

        <div class="nav-logo">
            <img src="/photo/logo.png" alt="Logo">
            <a href="#" class="nav-logo">Aspana Risol</a>
        </div>

        <div class="navbar-nav">
            <a href="#home">Home</a>
            <a href="#menu">Menu</a>
            <a href="#contact">Contact</a>
            <% if(user){ %>
                <a href="/pesanan-saya">
                    👤 Akun Saya
                </a>
                
                <a href="/user-logout">
                    Logout
                </a>

            <% } else { %>

                <a href="/user-login">
                    Login
                </a>
                
                <a href="/register">
                    Register
                </a>
            <% } %>
        </div>

        <div class="navbar-extra">
            <a href="#" id="search">
                <i data-feather="search"></i>
            </a>

            <a href="#" id="shopping">
                <i data-feather="shopping-cart"></i>
            </a>

            <a href="#" id="hamburger-menu">
                <i data-feather="menu"></i>
            </a>
        </div>

        <div class="search-form">
            <form>
                <input
                    type="search"
                    id="search-box"
                    placeholder="Search..."
                >
            </form>
        </div>

    </nav>

    <!-- Shopping Cart -->
    <div class="shopping-cart">

        <div class="cart-items"></div>

        <div class="cart-total">
            <h3>
                Total:
                <span id="total-harga">
                    Rp 0
                </span>
            </h3>
        </div>

        <div class="checkout-btn-container">
            <a href="/checkout" class="checkout-btn">
                Checkout
            </a>
        </div>

    </div>

    <!-- Hero -->
    <section class="hero" id="home">

        <div class="hero-content">

            <h1>
                Welcome to
                <span>Aspana Risol</span>
            </h1>

            <h2>
                Delicious Risoles for Every Occasion
            </h2>

            <p>
                Aspana Risol menghadirkan risoles homemade
                dengan kulit yang tipis dan crispy,
                isian premium, dan cita rasa lezat.
            </p>

            <a href="#menu" class="btn">
                Explore Our Menu
            </a>

        </div>

        <div class="hero-image">
            <img
                src="/photo/background.jpeg"
                alt="Aspana Risol"
            >
        </div>

    </section>

    <!-- Menu -->
    <section id="menu" class="menu">

        <h2>
            Our <span>Menu</span>
        </h2>

        <div class="menu-content">

            <% if (produk && produk.length > 0) { %>
            <% produk.forEach(function(data){ %>

            <div class="item" data-id="<%= data.id %>">

                <% if (data.gambar) { %>

    <img
        src="<%= data.gambar.startsWith('http')
            ? data.gambar
            : '/uploads/' + data.gambar %>"
        alt="<%= data.nama_produk %>"
        class="item-img"
    >

<% } else { %>

    <img
        src="/photo/no-image.png"
        alt="No Image"
        class="item-img"
    >

<% } %>

                <h3 class="item-title">
                    <%= data.nama_produk %>
                </h3>

                <p>
                    <%= data.deskripsi %>
                </p>

                <p>
                    Kategori:
                    <%= data.nama_kategori %>
                </p>

                <p class="item-harga">
                    Rp <%= Number(data.harga).toLocaleString("id-ID") %>
                </p>

                <button class="cart-btn">
                    Add To Cart
                </button>

            </div>

            <% }) %>
            <% } else { %>
            <div class="item" style="grid-column: 1 / -1;">
                <h3 class="item-title">Menu akan segera tersedia</h3>
                <p>Produk belum dapat dimuat karena database belum terhubung.</p>
            </div>
            <% } %>

        </div>

    </section>

    <!-- Contact -->
    <section id="contact" class="contact">

        <h2>
            <span>Contact</span> Us
        </h2>

        <h3>
            Have questions? Reach out to us!
        </h3>

        <div class="contact-content">

        <iframe
            class="contact-map"
            src="https://maps.google.com/maps?q=Aspana%20Risol&t=&z=15&ie=UTF8&iwloc=&output=embed"
            loading="lazy">
        </iframe>

            <div class="contact-info">

                <div class="contact-item">
                    <i data-feather="phone"></i>

                    <div>
                        <h4>Phone</h4>
                        <p>+62 81808359292</p>
                    </div>
                </div>

                <div class="contact-item">
                    <i data-feather="instagram"></i>

                    <div>
                        <h4>Instagram</h4>
                        <p>@aspanarisol</p>
                    </div>
                </div>

                <div class="contact-item">
                    <i data-feather="map-pin"></i>

                    <div>
                        <h4>Location</h4>
                        <p>
                            Gg. Rambutan Timur VI No.211A,
                            Jakarta Barat
                        </p>
                    </div>
                </div>

            </div>

        </div>

    </section>

    <!-- Footer -->
    <footer>

        <div class="credits">
            <p>
                Aspana Risol © 2026
            </p>
        </div>

    </footer>

    <script>
        feather.replace();
    </script>

    <script src="/js/script.js"></script>

</body>
</html>