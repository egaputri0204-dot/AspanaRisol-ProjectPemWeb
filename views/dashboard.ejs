<!DOCTYPE html>
<html>
  <head>
    <title>Dashboard Admin</title>

    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="dashboard-header">
      <button id="menu-toggle">
        <i data-feather="menu"></i>
      </button>

      <h2>Dashboard Admin</h2>
    </div>

    <div id="sidebar" class="sidebar">
      <button id="close-sidebar">
        <i data-feather="x"></i>
      </button>

      <h3>Menu Admin</h3>
      <a href="/kategori"> 📂 Kelola Kategori</a>
      <a href="/produk"> 🍽 Kelola Produk</a>
      <a href="/pesanan"> 📦 Data Pesanan</a>
      <a href="/logout">🚪 Logout</a>
    </div>

    <div class="admin-card">
      <h1 class="admin-title">Dashboard Admin</h1>

      <div class="welcome-box">
        <h3>👋 Selamat Datang,<span><%= admin.username %></span></h3>

        <p>
          Kelola produk, kategori, dan pesanan pelanggan dengan mudah melalui
          dashboard admin Aspana Risol.
        </p>
      </div>

      <div class="dashboard-cards">
        <div class="dashboard-card">
          <h3><%= statistik.totalKategori %></h3>
          <p>📂 Total Kategori</p>
        </div>

        <div class="dashboard-card">
          <h3><%= statistik.totalProduk %></h3>
          <p>🍽 Total Produk</p>
        </div>

        <div class="dashboard-card">
          <h3><%= statistik.totalPesanan %></h3>
          <p>📦 Total Pesanan</p>
        </div>

        <div class="dashboard-card">
          <h3><%= statistik.totalLunas %></h3>
          <p>✅ Sudah Lunas</p>
        </div>

        <div class="dashboard-card">
          <h3><%= statistik.totalBelumBayar %></h3>
          <p>⏳ Belum Bayar</p>
        </div>
      </div>

    <div class="summary-item">
      <h3>
        💰 Rp <%= Number(statistik.totalPendapatan).toLocaleString("id-ID") %>
      </h3>

      <p>Total Pendapatan Dari Pesanan Lunas</p>
    </div>

    <script>
      const menuToggle = document.getElementById("menu-toggle");

      const sidebar = document.getElementById("sidebar");

      const closeSidebar = document.getElementById("close-sidebar");

      menuToggle.addEventListener("click", () => {
        sidebar.classList.add("active");
      });

      closeSidebar.addEventListener("click", () => {
        sidebar.classList.remove("active");
      });
    </script>

    <script src="https://unpkg.com/feather-icons"></script>

    <script>
      feather.replace();
    </script>
  </body>
</html>
