<!DOCTYPE html>
<html>
<head>
    <title>Edit Produk</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="admin-card">

    <h2 class="admin-title">
        ✏ Edit Produk
    </h2>

    <form
        action="/produk/edit/<%= produk.id %>"
        method="POST"
        enctype="multipart/form-data"
        class="admin-form"
    >

        <label>Nama Produk</label>

        <input
            type="text"
            name="nama_produk"
            value="<%= produk.nama_produk %>"
            required
        >

        <label>Deskripsi</label>

        <textarea
            name="deskripsi"
            rows="4"
        ><%= produk.deskripsi %></textarea>

        <label>Harga</label>

        <input
            type="number"
            name="harga"
            value="<%= produk.harga %>"
            required
        >

        <label>Kategori</label>

        <select name="kategori_id">

            <% kategori.forEach(function(item){ %>

            <option
                value="<%= item.id %>"
                <%= item.id == produk.kategori_id ? 'selected' : '' %>
            >
                <%= item.nama_kategori %>
            </option>

            <% }) %>

        </select>

        <label>Gambar Saat Ini</label>
        
        <% if (produk.gambar) { %>
            
            <img
                src="<%= produk.gambar.startsWith('http') ? produk.gambar : '/uploads/' + produk.gambar %>"
                class="preview-image"
                width="180"
            >

        <% } else { %>

            <p>Belum ada gambar.</p>

        <% } %>
        
        <label>Ganti Gambar</label>

        <input
            type="file"
            name="gambar"
        >

        <div class="form-actions">

            <a
                href="/produk"
                class="btn-kembali"
            >
                ← Kembali
            </a>

            <button
                type="submit"
                class="btn-primary"
            >
                Update Produk
            </button>

        </div>

    </form>

</div>

</body>
</html>