<!DOCTYPE html>
<html>
  <head>
    <title>Login Admin</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="login-section">
      <div class="admin-card login-card">
        <div class="login-logo">
          <img src="/photo/logo.png" alt="Logo Aspana" />
        </div>

        <h1 class="admin-title">Admin Panel</h1>

        <p class="login-subtitle">
          Masuk untuk mengelola produk, kategori dan pesanan pelanggan.
        </p>

        <form action="/login" method="POST" class="admin-form">
          <label>Username</label>

          <input
            type="text"
            name="username"
            placeholder="Masukkan username"
            required
          />

          <label>Password</label>

          <input
            type="password"
            name="password"
            placeholder="Masukkan password"
            required
          />

          <button type="submit" class="btn-primary login-btn">
            Login Admin
          </button>
        </form>

        <div class="login-footer">Aspana Risol Management System</div>
      </div>
    </div>
  </body>
</html>
