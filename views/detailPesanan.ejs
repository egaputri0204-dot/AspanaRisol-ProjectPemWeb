<!DOCTYPE html>
<html>
<head>
    <title>Detail Pesanan</title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="admin-card">

    <h2 class="admin-title">
        📦 Detail Pesanan #<%= pesanan_id %>
    </h2>

    <div class="detail-info">

    <p>
        <strong>Nama Pembeli :</strong>
        <%= pesanan.nama_pembeli %>
    </p>

    <p>
        <strong>No HP :</strong>
        <%= pesanan.no_hp %>
    </p>

    <p>
        <strong>Tanggal :</strong>

        <%= new Date(pesanan.tanggal).toLocaleString("id-ID", {
            day: "numeric",
            month: "long",
            year: "numeric",
            hour: "2-digit",
            minute: "2-digit"
        }) %>
    </p>

    <p>
        <strong>Status :</strong>

        <span class="
            <%=
            pesanan.status === 'Pending'
            ? 'status-pending'
            : pesanan.status === 'Diproses'
            ? 'status-diproses'
            : 'status-selesai'
            %>
        ">
            <%= pesanan.status %>
        </span>

    </p>

    <p>
        <strong>Metode Pembayaran :</strong>
        <%= pesanan.metode_pembayaran || '-' %>
    </p>

    <p>
        <strong>Status Pembayaran :</strong>
        
        <span class="
        <%= pesanan.status_pembayaran === 'Lunas'
            ? 'status-selesai'
            : pesanan.status_pembayaran === 'Menunggu Verifikasi'
            ? 'status-diproses'
            : 'status-pending'
        %>
        ">
            <%= pesanan.status_pembayaran %>
        </span>
    </p>
    
    <p>
        <strong>Bukti Pembayaran :</strong>
    </p>
    
    <% if (pesanan.bukti_pembayaran) { %>
        
    <div class="payment-info">
        
        <a
            href="<%= pesanan.bukti_pembayaran %>"
            target="_blank"
        >
        
            <img
                src="<%= pesanan.bukti_pembayaran %>"
                alt="Bukti Pembayaran"
                class="bukti-admin"
            >
        </a>

        <% if(
            pesanan.bukti_pembayaran &&
            pesanan.status_pembayaran !== 'Lunas'
        ){ %>
            
        <br>
        
        <a
            href="/pesanan/verifikasi/<%= pesanan.id %>"
        class="btn-primary"
        >

            ✓ Verifikasi Pembayaran
        </a>

        <% } %>
    </div>
    
    <% } else { %>
        
    <p style="color:red;">
        Belum upload bukti Pembayaran
    </p>
    
    <% } %>

</div>

    <div class="detail-header">

        <div class="summary-item">
            <h3><%= detail.length %></h3>
            <p>Total Item</p>
        </div>

    </div>

    <a href="/pesanan" class="btn-kembali">
        ← Kembali ke Data Pesanan
    </a>

    <br><br>

    <div class="admin-table-wrapper">

        <table class="admin-table">

            <thead>
                <tr>
                    <th>Produk</th>
                    <th>Harga</th>
                    <th>Jumlah</th>
                    <th>Subtotal</th>
                </tr>
            </thead>

            <tbody>

                <% let total = 0; %>

                <% detail.forEach(function(item){ %>

                <% total += item.harga * item.jumlah; %>

                <tr>

                    <td>
                        <%= item.nama_produk %>
                    </td>

                    <td>
                        Rp <%= Number(item.harga).toLocaleString("id-ID") %>
                    </td>

                    <td>
                        <%= item.jumlah %>
                    </td>

                    <td>
                        Rp <%= Number(item.harga * item.jumlah).toLocaleString("id-ID") %>
                    </td>

                </tr>

                <% }) %>

            </tbody>

            <tfoot>
                <tr>
                    <th colspan="3">
                        Total Pesanan
                    </th>

                    <th>
                        Rp <%= Number(total).toLocaleString("id-ID") %>
                    </th>
                </tr>
            </tfoot>

        </table>

    </div>

</div>

</body>
</html>