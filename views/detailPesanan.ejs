<!DOCTYPE html>
<html>
<head>
    <title>Detail Pesanan</title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="admin-card">

    <h2 class="admin-title">
        📦 Detail Pesanan #<%= pesanan_id %>
    </h2>

    <div class="detail-info">

    <p>
        <strong>Nama Pembeli :</strong>
        <%= pesanan.nama_pembeli %>
    </p>

    <p>
        <strong>No HP :</strong>
        <%= pesanan.no_hp %>
    </p>

    <p>
        <strong>Tanggal :</strong>

        <%= new Date(pesanan.tanggal).toLocaleString("id-ID", {
            day: "numeric",
            month: "long",
            year: "numeric",
            hour: "2-digit",
            minute: "2-digit"
        }) %>
    </p>

    <p>
        <strong>Status :</strong>

        <span class="
            <%=
            pesanan.status === 'Pending'
            ? 'status-pending'
            : pesanan.status === 'Diproses'
            ? 'status-diproses'
            : 'status-selesai'
            %>
        ">
            <%= pesanan.status %>
        </span>

    </p>

</div>

    <div class="detail-header">

        <div class="summary-item">
            <h3><%= detail.length %></h3>
            <p>Total Item</p>
        </div>

    </div>

    <a href="/pesanan" class="btn-kembali">
        ← Kembali ke Data Pesanan
    </a>

    <br><br>

    <div class="admin-table-wrapper">

        <table class="admin-table">

            <thead>
                <tr>
                    <th>Produk</th>
                    <th>Harga</th>
                    <th>Jumlah</th>
                    <th>Subtotal</th>
                </tr>
            </thead>

            <tbody>

                <% let total = 0; %>

                <% detail.forEach(function(item){ %>

                <% total += item.harga * item.jumlah; %>

                <tr>

                    <td>
                        <%= item.nama_produk %>
                    </td>

                    <td>
                        Rp <%= Number(item.harga).toLocaleString("id-ID") %>
                    </td>

                    <td>
                        <%= item.jumlah %>
                    </td>

                    <td>
                        Rp <%= Number(item.harga * item.jumlah).toLocaleString("id-ID") %>
                    </td>

                </tr>

                <% }) %>

            </tbody>

            <tfoot>
                <tr>
                    <th colspan="3">
                        Total Pesanan
                    </th>

                    <th>
                        Rp <%= Number(total).toLocaleString("id-ID") %>
                    </th>
                </tr>
            </tfoot>

        </table>

    </div>

</div>

</body>
</html>