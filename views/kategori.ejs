<!DOCTYPE html>
<html>
<head>
    <title>Data Kategori</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="container">

<h2>📂 Data Kategori</h2>

<a href="/kategori/tambah">
    + Tambah Kategori
</a>

<br><br>

<table>

<tr>
    <th>ID</th>
    <th>Nama Kategori</th>
    <th>Aksi</th>
</tr>

<% kategori.forEach(function(item){ %>

<tr>
    <td><%= item.id %></td>
    <td><%= item.nama_kategori %></td>

    <td>
        <a href="/kategori/edit/<%= item.id %>">
            Edit
        </a>

        |

        <a href="/kategori/hapus/<%= item.id %>"
           onclick="return confirm('Yakin ingin menghapus kategori ini?')">
            Hapus
        </a>
    </td>
</tr>

<% }) %>

</table>

</div>

</body>
</html>