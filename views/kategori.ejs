<!DOCTYPE html>
<html>
<head>
    <title>Data Kategori</title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="admin-card">

    <h2 class="admin-title">
        📂 Data Kategori
    </h2>

    <a href="/dashboard" class="btn-kembali">
        ← Dashboard
    </a>

    <a href="/kategori/tambah" class="btn-tambah">
        + Tambah Kategori
    </a>

    <br><br>

    <div class="admin-table-wrapper">

        <table class="admin-table">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nama Kategori</th>
                    <th>Aksi</th>
                </tr>
            </thead>

            <tbody>

            <% kategori.forEach(function(item){ %>

                <tr>

                    <td>
                        <%= item.id %>
                    </td>

                    <td>
                        <%= item.nama_kategori %>
                    </td>

                    <td class="action-buttons">
                        <a href="/kategori/edit/<%= item.id %>" class="btn-edit">
                            Edit
                        </a>
                        
                        <a href="/kategori/hapus/<%= item.id %>" class="btn-hapus">
                            Hapus
                        </a>
                    </td>

                </tr>

            <% }) %>

            </tbody>

        </table>

    </div>

</div>

</body>
</html>