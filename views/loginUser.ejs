<!DOCTYPE html>
<html>
  <head>
    <title>Login User</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <div class="login-section">
      <div class="admin-card login-card">
        <div class="login-logo">
          <img src="/photo/logo.png" alt="Logo Aspana" />
        </div>

        <h1 class="admin-title">Login Pelanggan</h1>

        <p class="login-subtitle">Masuk untuk melakukan pemesanan</p>

        <form action="/user-login" method="POST" class="admin-form">
          <label>Username</label>

          <input
            type="text"
            name="username"
            placeholder="Masukkan username"
            required
          />

          <label>Password</label>

          <input
            type="password"
            name="password"
            placeholder="Masukkan password"
            required
          />

          <button type="submit" class="btn-primary login-btn">Login</button>
        </form>

        <div class="login-footer">
          Belum punya akun?
          <a href="/register"> Daftar </a>
        </div>
      </div>
    </div>

    <% if (loginRequired) { %>
    <script>
        alert("Silakan login terlebih dahulu");
    </script>
    <% } %>

  </body>
</html>
