<!DOCTYPE html>
<html>
<head>
    <title>Tambah Produk</title>

    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="admin-card">

    <h2 class="admin-title">
        ➕ Tambah Produk
    </h2>

    <form
        action="/produk/tambah"
        method="POST"
        enctype="multipart/form-data"
        class="admin-form">

        <label>Nama Produk</label>

        <input
            type="text"
            name="nama_produk"
            placeholder="Masukkan nama produk"
            required>

        <label>Deskripsi</label>

        <textarea
            name="deskripsi"
            placeholder="Masukkan deskripsi produk">
        </textarea>

        <label>Harga</label>

        <input
            type="number"
            name="harga"
            placeholder="Masukkan harga produk"
            required>

        <label>Gambar Produk</label>

        <input
            type="file"
            name="gambar">

        <label>Kategori</label>

        <select
            name="kategori_id"
            required>

            <option value="">
                -- Pilih Kategori --
            </option>

            <% kategori.forEach(function(item){ %>

                <option value="<%= item.id %>">
                    <%= item.nama_kategori %>
                </option>

            <% }) %>

        </select>

        <div class="form-actions">

            <a href="/produk" class="btn-kembali">
                ← Kembali
            </a>

            <button
                type="submit"
                class="btn-primary">
                Simpan Produk
            </button>

        </div>

    </form>

</div>

</body>
</html>